{
  "name": "prisca-dezigns-remotion-ad",
  "version": "1.0.0",
  "description": "Prisca Dezigns animated ad — built with Remotion",
  "scripts": {
    "start": "npx remotion studio",
    "render": "npx remotion render PriscaAd out/PriscaAd.mp4",
    "render:story": "npx remotion render PriscaAdStory out/PriscaAdStory.mp4",
    "render:wide": "npx remotion render PriscaAdWide out/PriscaAdWide.mp4",
    "render:all": "npx remotion render PriscaAd out/PriscaAd.mp4 && npx remotion render PriscaAdStory out/PriscaAdStory.mp4"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.459",
    "@remotion/renderer": "^4.0.459",
    "remotion": "^4.0.459",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
